<view class="page">
  <view class="card">
    <view class="card-title">今日任务</view>
    <view wx:for="{{tasks}}" wx:key="id" class="task">
      <view class="task-main">
        <text class="task-name">{{item.name}}</text>
        <text class="task-status" wx:if="{{item.done}}">已完成</text>
        <text class="task-status pending" wx:else>待完成</text>
      </view>
      <button class="btn" size="mini" bindtap="onToggleDone" data-id="{{item.id}}">
        {{item.done ? '取消打卡' : '完成打卡'}}
      </button>
    </view>
  </view>
</view>

