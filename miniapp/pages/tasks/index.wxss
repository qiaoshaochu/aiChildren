.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.task {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task:last-child {
  border-bottom: none;
}

.task-main {
  flex: 1;
  margin-right: 16rpx;
}

.task-name {
  font-size: 28rpx;
  color: #333;
}

.task-status {
  display: block;
  font-size: 24rpx;
  color: #67c23a;
}

.task-status.pending {
  color: #f56c6c;
}

.btn {
  border-radius: 16rpx;
}

