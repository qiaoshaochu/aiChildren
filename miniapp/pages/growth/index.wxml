<view class="page">
  <view class="card">
    <view class="card-title">成长时间轴（示意）</view>
    <view class="timeline-item" wx:for="{{timeline}}" wx:key="id">
      <view class="dot"></view>
      <view class="timeline-content">
        <text class="time">{{item.date}}</text>
        <text class="text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">成长记录列表</view>
    <view wx:for="{{records}}" wx:key="id" class="record">
      <text class="date">{{item.date}}</text>
      <text class="cat">{{item.category}}</text>
      <text class="val">{{item.value}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">成长数据</view>
    <button class="btn" bindtap="onGrowthDataTap">查看成长数据（占位）</button>
  </view>
</view>

