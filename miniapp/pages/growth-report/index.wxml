<view class="page">
  <view class="header">
    <text class="title">成长记录</text>
    <navigator class="link" url="/pages/record-input/index?child_id={{child_id}}">+ 新增记录</navigator>
  </view>
  <view wx:if="{{list.length === 0}}" class="empty">暂无记录</view>
  <view wx:else class="list">
    <view wx:for="{{list}}" wx:key="id" class="item">
      <text class="date">{{item.record_date}}</text>
      <text class="cat">{{item.category}}</text>
      <text class="val">{{item.value}}</text>
      <text wx:if="{{item.notes}}" class="notes">{{item.notes}}</text>
    </view>
  </view>
</view>
