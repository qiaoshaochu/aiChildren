.page { padding: 24rpx; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.title { font-size: 36rpx; font-weight: 600; }
.link { font-size: 28rpx; color: #1989fa; }
.empty { padding: 60rpx; text-align: center; color: #999; font-size: 28rpx; }
.list { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 4rpx 12rpx rgba(0,0,0,.06); }
.item { padding: 24rpx; border-bottom: 1rpx solid #eee; }
.item:last-child { border-bottom: none; }
.date { font-size: 24rpx; color: #999; margin-right: 12rpx; }
.cat { font-size: 26rpx; color: #1989fa; margin-right: 8rpx; }
.val { font-size: 28rpx; }
.notes { display: block; font-size: 24rpx; color: #666; margin-top: 8rpx; }
