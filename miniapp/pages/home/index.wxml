<view class="page">
  <view class="header">
    <text class="title">我的孩子</text>
    <navigator class="link" url="/pages/child-manage/index">新增儿童</navigator>
  </view>
  <view wx:if="{{list.length === 0}}" class="empty">暂无儿童，点击「新增儿童」添加</view>
  <view wx:else class="list">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="item"
      bindtap="onChildTap"
      data-id="{{item.id}}"
    >
      <text class="name">{{item.name}}</text>
      <text class="meta">{{item.birth_date || '未填生日'}}</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
