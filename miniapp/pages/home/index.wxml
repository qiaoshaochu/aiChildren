<view class="page">
  <view class="welcome">
    <text class="welcome-title">成长小助手</text>
    <text class="welcome-sub">记录一点，看见成长</text>
  </view>

  <block wx:if="{{!defaultChild}}">
    <view class="empty-block">
      <view class="empty-icon">👶</view>
      <text class="empty-title">还没有添加孩子</text>
      <text class="empty-desc">添加孩子后，可以记录每日成长、查看成长报告</text>
      <navigator class="btn-primary" url="/pages/child-manage/index">添加孩子</navigator>
    </view>
  </block>

  <block wx:else>
    <view class="card child-card">
      <view class="card-label">当前孩子</view>
      <view class="child-name">{{defaultChild.name}}</view>
      <view class="child-meta" wx:if="{{defaultChild.birth_date}}">{{defaultChild.birth_date}}</view>
      <navigator class="card-link" url="/pages/child-manage/index">管理孩子</navigator>
    </view>

    <view class="actions">
      <navigator class="action-btn primary" url="/pages/record-input/index?child_id={{defaultChild.id}}">
        <text class="action-icon">✏️</text>
        <text class="action-text">新增成长记录</text>
      </navigator>
      <navigator class="action-btn" url="/pages/growth-report/index?child_id={{defaultChild.id}}">
        <text class="action-icon">📊</text>
        <text class="action-text">查看成长报告</text>
      </navigator>
    </view>

    <view class="card recent-card" wx:if="{{lastRecord}}">
      <view class="card-label">最近一条记录</view>
      <view class="recent-line">
        <text class="recent-date">{{lastRecord.record_date}}</text>
        <text class="recent-cat">{{lastRecord.category}}</text>
      </view>
      <view class="recent-value">{{lastRecord.value}}</view>
      <view class="recent-notes" wx:if="{{lastRecord.notes}}">{{lastRecord.notes}}</view>
      <navigator class="card-link" url="/pages/growth-report/index?child_id={{defaultChild.id}}">查看全部</navigator>
    </view>

    <view class="card recent-card recent-empty" wx:else>
      <view class="card-label">最近记录</view>
      <text class="recent-placeholder">暂无记录，去写一条吧</text>
      <navigator class="card-link" url="/pages/record-input/index?child_id={{defaultChild.id}}">新增记录</navigator>
    </view>
  </block>
</view>
