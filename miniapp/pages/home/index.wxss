@import "../../styles/base.wxss";

.welcome {
  margin-bottom: 32rpx;
}
.welcome-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}
.welcome-sub {
  font-size: 28rpx;
  color: #666666;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.card-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}
.card-link {
  display: inline-block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #4A90E2;
}

.child-card .child-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
}
.child-card .child-meta {
  font-size: 26rpx;
  color: #666666;
  margin-top: 4rpx;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.action-btn {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #EDEDED;
}
.action-btn.primary {
  background: linear-gradient(135deg, #4A90E2, #AF52DE);
  border: none;
}
.action-btn.primary .action-text {
  color: #fff;
}
.action-icon {
  display: block;
  font-size: 44rpx;
  margin-bottom: 8rpx;
}
.action-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.recent-card .recent-line {
  margin-bottom: 6rpx;
}
.recent-date {
  font-size: 24rpx;
  color: #999999;
  margin-right: 12rpx;
}
.recent-cat {
  font-size: 24rpx;
  color: #4A90E2;
}
.recent-value {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 500;
}
.recent-notes {
  font-size: 26rpx;
  color: #666666;
  margin-top: 8rpx;
}
.recent-empty .recent-placeholder {
  font-size: 28rpx;
  color: #999999;
}
