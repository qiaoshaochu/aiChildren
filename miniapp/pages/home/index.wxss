.page { padding: 24rpx; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.title { font-size: 36rpx; font-weight: 600; }
.link { font-size: 28rpx; color: #1989fa; }
.empty { padding: 60rpx; text-align: center; color: #999; font-size: 28rpx; }
.list { border-radius: 16rpx; overflow: hidden; background: #fff; box-shadow: 0 4rpx 12rpx rgba(0,0,0,.06); }
.item { display: flex; align-items: center; padding: 28rpx 24rpx; border-bottom: 1rpx solid #eee; }
.item:last-child { border-bottom: none; }
.name { font-size: 30rpx; font-weight: 500; flex: 1; }
.meta { font-size: 24rpx; color: #999; margin-right: 12rpx; }
.arrow { color: #ccc; font-size: 28rpx; }
