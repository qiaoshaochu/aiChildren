.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.welcome {
  margin-bottom: 32rpx;
}
.welcome-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}
.welcome-sub {
  font-size: 28rpx;
  color: #888;
}

.empty-block {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  line-height: 1.5;
}
.btn-primary {
  display: inline-block;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 48rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}
.card-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.card-link {
  display: inline-block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #1989fa;
}

.child-card .child-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}
.child-card .child-meta {
  font-size: 26rpx;
  color: #888;
  margin-top: 4rpx;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.action-btn {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #eee;
}
.action-btn.primary {
  background: linear-gradient(135deg, #1989fa, #0d6efd);
  border: none;
}
.action-btn.primary .action-text {
  color: #fff;
}
.action-icon {
  display: block;
  font-size: 44rpx;
  margin-bottom: 8rpx;
}
.action-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.recent-card .recent-line {
  margin-bottom: 6rpx;
}
.recent-date {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}
.recent-cat {
  font-size: 24rpx;
  color: #1989fa;
}
.recent-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
.recent-notes {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}
.recent-empty .recent-placeholder {
  font-size: 28rpx;
  color: #bbb;
}
