.home {
  padding-bottom: 24rpx;
}

.hero {
  background: radial-gradient(130% 150% at 0% 0%, #ffe4dd, #f3e8ff);
  position: relative;
  overflow: hidden;
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
}

.hero-left {
  max-width: 60%;
}

.sub {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.hero-streak {
  display: flex;
  align-items: center;
}

.hero-date {
  margin-top: 10rpx;
}

.hero-decor {
  position: absolute;
  border-radius: 999rpx;
  opacity: 0.7;
}

.hero-bubble-1 {
  width: 120rpx;
  height: 120rpx;
  right: -20rpx;
  top: -20rpx;
  background: rgba(255, 255, 255, 0.4);
}

.hero-bubble-2 {
  width: 80rpx;
  height: 80rpx;
  right: 40rpx;
  bottom: -20rpx;
  background: rgba(255, 255, 255, 0.25);
}

.hero-right {
  display: flex;
  align-items: center;
}

.growth-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 22rpx;
  padding: 14rpx 16rpx;
  min-width: 180rpx;
  text-align: right;
}

.growth-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #f97316;
  margin-top: 4rpx;
}

.growth-sub {
  margin-top: 2rpx;
}

.banner-wrapper {
  margin: 16rpx 0 8rpx;
}

.banner-swiper {
  height: 180rpx;
}

.banner-card {
  height: 160rpx;
  border-radius: 24rpx;
  padding: 22rpx 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.banner-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 100%;
}

.banner-text {
  flex: 1;
}

.banner-label {
  margin-bottom: 6rpx;
}

.banner-0 {
  background: linear-gradient(135deg, #ffb199, #ff8a7a);
}

.banner-1 {
  background: linear-gradient(135deg, #7c8cff, #a855f7);
}

.banner-2 {
  background: linear-gradient(135deg, #f97316, #f97393);
}

.banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.banner-sub {
  color: rgba(255, 255, 255, 0.9);
}

.banner-illustration {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  margin-left: 16rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.7);
  opacity: 0.9;
}

.main-task {
  margin-top: 8rpx;
  background: linear-gradient(135deg, #ffe8dd, #fff7f2);
}

.task-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5b8cff, #7c5cff);
  margin-top: 10rpx;
  margin-right: 14rpx;
  flex: none;
}

.task-text {
  font-size: 28rpx;
  line-height: 1.45;
  color: rgba(15, 23, 42, 0.82);
}

.actions button {
  min-width: 220rpx;
}

.kv {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.k {
  width: 140rpx;
  color: rgba(15, 23, 42, 0.55);
  font-size: 24rpx;
  flex: none;
}

.v {
  color: rgba(15, 23, 42, 0.82);
  font-size: 26rpx;
  line-height: 1.5;
}

.quote {
  font-size: 28rpx;
  line-height: 1.6;
  color: rgba(15, 23, 42, 0.86);
  padding: 18rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(91, 140, 255, 0.08);
  border: 1rpx solid rgba(91, 140, 255, 0.14);
}

.tip {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.nav-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.nav-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx 20rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(15, 23, 42, 0.04);
}

.nav-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  margin-bottom: 12rpx;
}

.nav-icon.i1 {
  background: linear-gradient(135deg, rgba(91, 140, 255, 1), rgba(124, 92, 255, 1));
}

.nav-icon.i2 {
  background: linear-gradient(135deg, rgba(34, 197, 94, 1), rgba(16, 185, 129, 1));
}

.nav-icon.i3 {
  background: linear-gradient(135deg, rgba(251, 113, 133, 1), rgba(249, 115, 22, 1));
}

.nav-icon.i4 {
  background: linear-gradient(135deg, rgba(168, 85, 247, 1), rgba(236, 72, 153, 1));
}

.nav-title {
  font-size: 28rpx;
  font-weight: 800;
  color: rgba(15, 23, 42, 0.9);
}

.nav-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(15, 23, 42, 0.55);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 24rpx 0 20rpx;
  color: rgba(15, 23, 42, 0.9);
}

.inspo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.inspo-card {
  background: #ffffff;
  border-radius: 22rpx;
  padding: 18rpx 18rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(15, 23, 42, 0.04);
}

.inspo-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 10rpx;
}

.inspo-title {
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.92);
  margin-bottom: 4rpx;
}

.inspo-desc {
  font-size: 24rpx;
  color: rgba(15, 23, 42, 0.7);
  margin-bottom: 6rpx;
}

.inspo-meta {
  font-size: 22rpx;
}
