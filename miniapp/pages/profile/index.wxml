<view class="page">
  <view class="card">
    <view class="card-title">孩子管理</view>
    <view class="item" bindtap="onChildManageTap">
      <text class="text">管理孩子信息</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">我的任务</view>
    <view class="item" bindtap="onMyTasksTap">
      <text class="text">查看我的任务</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">我的 BusyBook</view>
    <view class="item" bindtap="onMyBusybookTap">
      <text class="text">查看我的 BusyBook 作品</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">设置</view>
    <view class="item" bindtap="onSettingsTap">
      <text class="text">通知与偏好设置</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>

