<view class="page">
  <view class="form">
    <view class="field">
      <text class="label">孩子 ID</text>
      <input class="input" type="number" placeholder="必填，如 1" value="{{child_id}}" bindinput="onChildIdInput" />
    </view>
    <view class="field">
      <text class="label">记录日期</text>
      <input class="input" placeholder="选填，如 2025-03-10" value="{{record_date}}" bindinput="onDateInput" />
    </view>
    <view class="field">
      <text class="label">类别</text>
      <input class="input" placeholder="必填，如 reading" value="{{category}}" bindinput="onCategoryInput" />
    </view>
    <view class="field">
      <text class="label">内容</text>
      <input class="input" placeholder="必填" value="{{value}}" bindinput="onValueInput" />
    </view>
    <view class="field">
      <text class="label">备注</text>
      <input class="input" placeholder="选填" value="{{notes}}" bindinput="onNotesInput" />
    </view>
    <button class="btn" bindtap="onSubmit" loading="{{loading}}">保存</button>
  </view>
</view>
