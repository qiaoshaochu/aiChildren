.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  max-width: 680rpx;
  margin: 0 auto;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.form {
  width: 100%;
}

.field {
  margin-bottom: 28rpx;
}

.field:last-of-type {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 1rpx solid #e5e5e5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.input::placeholder {
  color: #bbb;
}

.btn {
  margin-top: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn::after {
  border: none;
}
