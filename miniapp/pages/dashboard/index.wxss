 .dashboard {
  padding-bottom: 32rpx;
}

.overview {
  margin-bottom: 20rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.overview-item {
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  background: #fef2f2;
}

.overview-item:nth-child(2) {
  background: #eff6ff;
}

.overview-item:nth-child(3) {
  background: #ecfdf3;
}

.label {
  font-size: 22rpx;
  color: rgba(24, 34, 48, 0.6);
}

.value {
  font-size: 34rpx;
  font-weight: 800;
  color: #182230;
  margin-top: 4rpx;
  margin-bottom: 4rpx;
}

.summary-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(24, 34, 48, 0.86);
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 138, 122, 0.06);
}

.section {
  margin-top: 12rpx;
}

.record-row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.04);
}

.record-row:last-child {
  border-bottom: none;
}

.record-date {
  width: 120rpx;
  font-size: 24rpx;
  color: rgba(24, 34, 48, 0.6);
}

.record-main {
  flex: 1;
  margin-left: 12rpx;
}

.record-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #182230;
  margin-bottom: 4rpx;
}

.peer {
  margin-top: 16rpx;
}

.peer-row {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.peer-item {
  flex: 1;
}

.peer-item + .peer-item {
  margin-left: 8rpx;
}

.badge {
  margin-top: 4rpx;
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(15, 23, 42, 0.06);
  color: #182230;
}

.tip {
  margin-top: 12rpx;
}

