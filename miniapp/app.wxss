/* ========= 设计系统：颜色 ========= */

page {
  background: #f7f8fc;
  color: #182230;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

/* 主色：温柔粉橘，辅色：浅蓝紫 */
:root,
page {
  --color-primary: #ff8a7a;
  --color-primary-soft: rgba(255, 138, 122, 0.12);
  --color-primary-deep: #f55b5b;

  --color-accent: #7c8cff;
  --color-accent-soft: rgba(124, 140, 255, 0.12);

  --color-success: #22c55e;
  --color-warning: #f97316;
  --color-danger: #ef4444;

  --color-text-main: #182230;
  --color-text-sub: rgba(24, 34, 48, 0.72);
  --color-text-mute: rgba(24, 34, 48, 0.55);

  --color-border-soft: rgba(15, 23, 42, 0.06);
  --color-card-bg: #ffffff;
}

/* ========= 布局与间距 ========= */

.container {
  padding: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row-center {
  display: flex;
  align-items: center;
}

.gap8 {
  height: 8rpx;
}

.gap12 {
  height: 12rpx;
}

.gap16 {
  height: 16rpx;
}

.gap24 {
  height: 24rpx;
}

/* ========= 字体层级 ========= */

.h1 {
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
  color: var(--color-text-main);
}

.h2 {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-main);
}

.h3 {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-main);
}

.body {
  font-size: 26rpx;
  color: var(--color-text-sub);
}

.caption {
  font-size: 22rpx;
  color: var(--color-text-mute);
}

.muted {
  color: var(--color-text-mute);
}

/* ========= 卡片 ========= */

.card {
  background: var(--color-card-bg);
  border-radius: 24rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid var(--color-border-soft);
}

.card-flat {
  background: var(--color-card-bg);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid var(--color-border-soft);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-main);
}

.card-subtitle {
  font-size: 26rpx;
  color: var(--color-text-sub);
}

/* ========= 按钮 ========= */

.primary-btn {
  background: linear-gradient(135deg, #ffb199, #ff8a7a);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 36rpx rgba(255, 137, 122, 0.4);
  border: none;
}

.primary-btn[disabled] {
  opacity: 0.6;
  box-shadow: none;
}

.secondary-btn {
  background: rgba(24, 34, 48, 0.06);
  color: var(--color-text-main);
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.ghost-btn {
  background: transparent;
  color: var(--color-text-mute);
  border-radius: 999rpx;
  border: 1rpx dashed var(--color-border-soft);
  font-size: 24rpx;
}

/* ========= 表单 ========= */

.form-card {
  background: var(--color-card-bg);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid var(--color-border-soft);
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 26rpx;
  color: var(--color-text-mute);
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  box-sizing: border-box;
  background: #f9fafb;
  border-radius: 999rpx;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.4);
}

.input::placeholder {
  color: rgba(148, 163, 184, 0.9);
}

.textarea {
  width: 100%;
  box-sizing: border-box;
  background: #f9fafb;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  font-size: 26rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.4);
}

/* ========= pill 标签 ========= */

.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: var(--color-primary-soft);
  color: var(--color-primary-deep);
}

.pill-accent {
  background: var(--color-accent-soft);
  color: var(--color-accent);
}

.pill-gray {
  background: rgba(15, 23, 42, 0.06);
  color: var(--color-text-mute);
}

.pill-success {
  background: rgba(34, 197, 94, 0.12);
  color: #16a34a;
}

/* ========= Section 标题 ========= */

.section-label {
  margin: 4rpx 0 12rpx;
  font-size: 26rpx;
  color: var(--color-text-mute);
  font-weight: 600;
}

/* ========= 阴影 / 分割线 ========= */

.divider {
  height: 1rpx;
  background: var(--color-border-soft);
  margin: 16rpx 0;
}

/* ========= 空状态 ========= */

.empty {
  text-align: center;
  padding: 60rpx 24rpx;
  color: var(--color-text-mute);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffe4dd, #f3e8ff);
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.empty-sub {
  font-size: 24rpx;
}

